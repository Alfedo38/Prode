// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Series {
  id             String       @id @default(cuid())
  mlbSeriesId    String       @unique 
  homeTeam       String
  awayTeam       String
  startDate      DateTime     
  endDate        DateTime     
  firstGameTime  DateTime     
  status         String       @default("UPCOMING") 
  winnerId       String?      
  score          String?      
  predictions    Prediction[]
}

model Prediction {
  id                String   @id @default(cuid())
  userId            String   
  seriesId          String   
  predictedWinnerId String   
  predictedScore    String   
  dailyPicks        String?  // Ej: "V,L,L"
  pitcherPicks      String?  // ✅ NUEVO: Ej: "Mitch Keller,Sean Manaea,Bailey Falter"
  totalRuns         Int      @default(0) 
  pointsEarned      Int      @default(0) 
  createdAt         DateTime @default(now())

  series            Series   @relation(fields: [seriesId], references: [id])
  @@unique([userId, seriesId])
}

model FantasyTeam {
  id           String   @id @default(cuid())
  userId       String   @unique 
  playerNames  String   
  pointsEarned Int      @default(0) 
  updatedAt    DateTime @updatedAt
}