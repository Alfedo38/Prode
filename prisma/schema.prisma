// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Series {
  id            String       @id @default(cuid())
  mlbSeriesId   String       @unique 
  homeTeam      String
  awayTeam      String
  startDate     DateTime     
  endDate       DateTime     
  firstGameTime DateTime     
  status        String       @default("UPCOMING") 
  winnerId      String?      
  score         String?      
  predictions   Prediction[]
}

model Prediction {
  id                String   @id @default(cuid())
  userId            String   
  seriesId          String   
  predictedWinnerId String   
  predictedScore    String   
  dailyPicks        String?  // Ej: "V,L,L"
  pitcherPicks      String?  // ✅ Ej: "SI,NO,SI" (Abridor gana)
  totalRuns         Int      @default(0) 
  pointsEarned      Int      @default(0) 
  
  pointsDetail      Json?    // 🧾 NUEVO: EL RECIBO DE PUNTOS DETALLADO
  
  createdAt         DateTime @default(now())

  series            Series   @relation(fields: [seriesId], references: [id])
  @@unique([userId, seriesId])
}

model FantasyTeam {
  id           String   @id @default(cuid())
  userId       String   @unique 
  playerNames  String   
  pointsEarned Int      @default(0) 
  updatedAt    DateTime @updatedAt
}

// ==========================================
// 🏆 NUEVO: SALAS DE AMIGOS (LIGAS PRIVADAS)
// ==========================================

model League {
  id          String         @id @default(cuid())
  name        String         // Ej: "Oficina Béisbol"
  inviteCode  String         @unique // Código secreto único, Ej: "PRODE123"
  ownerId     String         // El userId (Clerk) del creador
  createdAt   DateTime       @default(now())

  members     LeagueMember[] // Relación con los jugadores adentro
}

model LeagueMember {
  id        String   @id @default(cuid())
  leagueId  String
  userId    String   // El userId (Clerk) del jugador que se unió
  joinedAt  DateTime @default(now())

  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  // 🛡️ Regla de oro: Un jugador no puede unirse dos veces a la misma sala
  @@unique([leagueId, userId])
}